# Postgres (e.g. Neon connection string)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Anthropic API key (Claude Haiku is used for parsing spoken expenses)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Deepgram API key (streaming speech-to-text, supports Russian: language=ru)
DEEPGRAM_API_KEY=xxxx

# Origin of the deployed frontend, for CORS
FRONTEND_URL=https://your-frontend.vercel.app

PORT=3001
